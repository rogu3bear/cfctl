# Canonical shared source of truth lives in ~/.config/cfctl/.env by default.
# This file exists to document the contract only.

CF_DEV_TOKEN=
CF_GLOBAL_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Select dev by default; set to global only for emergency wider-scope operations.
CF_TOKEN_LANE=dev

# Required for the emergency global lane.
CLOUDFLARE_EMAIL=

# Derived compatibility env for Wrangler wrappers.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_API_KEY=

# Access service tokens are only for calling Access-protected applications.
CLOUDFLARE_ACCESS_CLIENT_ID=
CLOUDFLARE_ACCESS_CLIENT_SECRET=

# Tunnel runtime values when operating cloudflared directly.
CF_TUNNEL_ID=
CF_TUNNEL_TOKEN=
