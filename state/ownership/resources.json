    {
      "id": "cfctl-hostname-lifecycle-state",
      "resource_key": "cloudflare:hostname:*",
      "resource": {
        "cloudflare_surface": "hostname",
        "scope": "composite",
        "selectors": {
          "managed_specs": "state/hostname/*.yaml"
        }
      },
      "owner": {
        "system": "cfctl",
        "repo": "rogu3bear/cfctl",
        "role": "cloudflare-control-plane"
      },
      "deploy_lane": {
        "default": "CF_DEV_TOKEN",
        "emergency": "CF_GLOBAL_TOKEN"
      },
      "secrets": {
        "env": ["CF_DEV_TOKEN", "CF_GLOBAL_TOKEN", "CLOUDFLARE_ACCOUNT_ID"],
        "source": "~/.config/cfctl/.env"
      },
      "domain": ["from state/hostname/*.yaml"],
      "worker_page": ["from state/hostname/*.yaml"],
      "database_storage": ["from state/hostname/*.yaml"],
      "authority": {
        "control_plane": "cfctl",
        "allowed_change_commands": [
          "cfctl hostname plan --file state/hostname/<spec>.yaml",
          "cfctl apply <component-surface> <operation> --plan",
          "cfctl apply <component-surface> <operation> --ack-plan <operation-id>"
        ],
        "verifier": "cfctl hostname verify --file state/hostname/<spec>.yaml",
        "proof_class": "post_change_verification"
      },
      "incident_runbook": "state/hostname/README.md"
    },
