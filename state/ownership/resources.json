{
  "version": 1,
  "resources": [
    {
      "id": "cfctl-access-app-state",
      "resource_key": "cloudflare:access.app:*",
      "resource": {
        "cloudflare_surface": "access.app",
        "scope": "account",
        "selectors": {
          "managed_specs": "state/access.app/*.json"
        }
      },
      "owner": {
        "system": "cfctl",
        "repo": "rogu3bear/cfctl",
        "role": "cloudflare-control-plane"
      },
      "deploy_lane": {
        "default": "CF_DEV_TOKEN",
        "emergency": "CF_GLOBAL_TOKEN"
      },
      "secrets": {
        "env": ["CF_DEV_TOKEN", "CF_GLOBAL_TOKEN", "CLOUDFLARE_ACCOUNT_ID"],
        "source": "~/.config/cfctl/.env"
      },
      "domain": [],
      "worker_page": [],
      "database_storage": [],
      "authority": {
        "control_plane": "cfctl",
        "allowed_change_commands": [
          "cfctl apply access.app sync --plan",
          "cfctl apply access.app sync --ack-plan <operation-id>"
        ],
        "verifier": "cfctl verify access.app <selectors>",
        "proof_class": "post_change_verification"
      },
      "incident_runbook": "AGENTS.md#evidence-contract"
    },
