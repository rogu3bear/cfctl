      "replacement": "./cfctl list zone"
    },
    {
      "legacy_path": "scripts/cf_inventory_pages.sh",
      "replacement": "./cfctl list pages.project"
    },
    {
      "legacy_path": "scripts/cf_inventory_workers.sh",
      "replacement": "./cfctl list worker.script"
    },
    {
      "legacy_path": "scripts/cf_inventory_d1.sh",
      "replacement": "./cfctl list d1.database"
    },
    {
      "legacy_path": "scripts/cf_inventory_r2.sh",
      "replacement": "./cfctl list r2.bucket"
    },
    {
      "legacy_path": "scripts/cf_inventory_queues.sh",
      "replacement": "./cfctl list queue"
    },
    {
      "legacy_path": "scripts/cf_inventory_workflows.sh",
      "replacement": "./cfctl list workflow"
    },
    {
      "legacy_path": "scripts/cf_inventory_access.sh",
      "replacement": "./cfctl list access.app"
    },
    {
      "legacy_path": "scripts/cf_inventory_turnstile.sh",
      "replacement": "./cfctl list turnstile.widget"
    },
    {
