    {
      "legacy_path": "scripts/cf_mutate_access_app.sh",
      "replacement": "./cfctl apply access.app <operation> ...",
      "mode": "backend_only"
    },
    {
      "legacy_path": "scripts/cf_mutate_access_policy.sh",
      "replacement": "./cfctl apply access.policy <operation> ...",
      "mode": "backend_only"
    },
    {
      "legacy_path": "scripts/cf_mutate_dns_record.sh",
      "replacement": "./cfctl apply dns.record <operation> ...",
      "mode": "backend_only"
    },
    {
      "legacy_path": "scripts/cf_mutate_tunnel.sh",
      "replacement": "./cfctl apply tunnel <operation> ...",
      "mode": "backend_only"
    },
    {
      "legacy_path": "scripts/cf_api_apply.sh",
      "replacement": "./cfctl apply <surface> <operation> ...",
      "mode": "backend_only"
    },
    {
      "legacy_path": "scripts/cf_token_mint.sh",
      "replacement": "./cfctl token mint ...",
      "mode": "backend_only"
    }
  ]
}
