    {
      "legacy_path": "scripts/cf_inventory_waiting_rooms.sh",
      "replacement": "./cfctl list waiting_room --zone <zone>"
    },
    {
      "legacy_path": "scripts/cf_inventory_logpush.sh",
      "replacement": "./cfctl list logpush.job"
    },
    {
      "legacy_path": "scripts/cf_inventory_tunnels.sh",
      "replacement": "./cfctl list tunnel"
    },
    {
      "legacy_path": "scripts/cf_auth_check.sh",
      "replacement": "./cfctl lanes"
    },
    {
      "legacy_path": "scripts/cf_probe_token_permissions.sh",
      "replacement": "./cfctl can <surface> <operation> --all-lanes"
