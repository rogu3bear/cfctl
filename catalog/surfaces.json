    "access.app": {
      "description": "Cloudflare Access applications in the pinned account.",
      "module": "access_app",
      "standards_ref": "access.app",
      "docs_topics": ["zero-trust-api", "api-auth"],
      "backend": "inventory_script",
      "inventory_script": "scripts/cf_inventory_access.sh",
      "apply_script": "scripts/cf_mutate_access_app.sh",
      "permission_family": "Access: Apps and Policies",
      "probe": {
        "method": "GET",
        "path_template": "/accounts/{account_id}/access/apps"
      },
      "selectors": ["id", "name", "domain"],
      "actions": {
        "list": {
          "supported": true
        },
        "get": {
          "supported": true,
          "selectors_any_of": [["id"], ["name"], ["domain"]]
        },
        "verify": {
          "supported": true,
          "selectors_any_of": [["id"], ["name"], ["domain"]]
        },
        "can": {
          "supported": true
        },
        "apply": {
          "supported": true,
          "operations": {
            "create": {
              "risk": "write"
            },
            "update": {
              "risk": "write",
              "required_selectors": ["id"]
            },
            "delete": {
              "risk": "destructive",
              "required_selectors": ["id"],
              "confirm": "delete"
            }
          }
        }
      },
      "examples": [
        "./cfctl list access.app",
        "./cfctl get access.app --domain docs.example.org",
        "./cfctl apply access.app update --id <app-id> --body '{\"session_duration\":\"24h\"}' --plan"
      ]
    },
    "access.policy": {
      "description": "Application-scoped Access policies attached to Access apps.",
      "module": "access_policy",
      "standards_ref": "access.policy",
      "docs_topics": ["zero-trust-api", "api-auth"],
      "backend": "inventory_script",
      "inventory_script": "scripts/cf_inventory_access.sh",
      "apply_script": "scripts/cf_mutate_access_policy.sh",
      "permission_family": "Access: Apps and Policies",
      "selectors": ["app_id", "policy_id", "name"],
      "actions": {
        "list": {
          "supported": true
        },
        "get": {
          "supported": true,
          "selectors_any_of": [["policy_id"], ["app_id", "name"]]
        },
        "verify": {
          "supported": true,
          "selectors_any_of": [["policy_id"], ["app_id", "name"]]
        },
        "can": {
          "supported": true
        },
        "apply": {
          "supported": true,
          "operations": {
            "create": {
              "risk": "write",
              "required_selectors": ["app_id"]
            },
            "update": {
              "risk": "write",
              "required_selectors": ["app_id", "policy_id"]
            },
            "delete": {
              "risk": "destructive",
              "required_selectors": ["app_id", "policy_id"],
              "confirm": "delete"
            },
            "make-reusable": {
              "risk": "write",
              "required_selectors": ["app_id", "policy_id"]
            }
          }
        }
      },
      "examples": [
        "./cfctl list access.policy",
        "./cfctl get access.policy --policy-id <policy-id>",
        "./cfctl apply access.policy create --app-id <app-id> --body-file policy.json --plan"
      ]
