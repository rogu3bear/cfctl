  "version": 1,
  "surfaces": {
    "zone": {
      "description": "Cloudflare zones in the pinned account.",
      "backend": "inventory_script",
      "inventory_script": "scripts/cf_inventory_zones.sh",
      "permission_family": "Zone",
      "probe": {
        "method": "GET",
        "path_template": "/zones?per_page=1&account.id={account_id}"
      },
      "selectors": ["id", "name"],
      "actions": {
        "list": {
          "supported": true
        },
        "get": {
          "supported": true,
          "selectors_any_of": [["id"], ["name"]]
        },
        "verify": {
          "supported": true,
          "selectors_any_of": [["id"], ["name"]]
        },
        "can": {
          "supported": true
        },
        "apply": {
          "supported": false
        }
      },
      "examples": [
        "./cfctl list zone",
        "./cfctl get zone --name example.com"
      ]
    },
